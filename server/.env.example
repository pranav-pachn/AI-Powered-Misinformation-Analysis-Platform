# Server Configuration
PORT=5000
NODE_ENV=production

# CORS Configuration
# Comma-separated list of allowed origins, e.g. https://app.vercel.app,https://admin.vercel.app
CORS_ORIGIN=https://your-frontend.onrender.com

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=fake_news_detection
DB_SSL=false
DB_CONNECT_RETRIES=5
DB_CONNECT_RETRY_DELAY_MS=2000

# MongoDB (optional)
# If you want to use MongoDB instead of MySQL, set these values.
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB_NAME=fake_news_detection
MONGO_CONNECT_RETRIES=5
MONGO_CONNECT_RETRY_DELAY_MS=2000

# AI Providers
OPENROUTER_API_KEY=your_openrouter_api_key
# Optional: comma-separated pool of OpenRouter keys for rotation
# OPENROUTER_API_KEYS=key_one,key_two
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
OPENROUTER_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free

GROQ_API_KEY=your_groq_api_key
# Optional: comma-separated pool of Groq keys for rotation
# GROQ_API_KEYS=key_one,key_two
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=openai/gpt-oss-120b

# Legacy Gemini fallback support
# GEMINI_API_KEY=your_google_gemini_api_key
# GEMINI_API_KEYS=key_one,key_two
# GOOGLE_API_KEY=your_google_gemini_api_key
GOOGLE_FACT_CHECK_API_KEY=your_fact_check_api_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
